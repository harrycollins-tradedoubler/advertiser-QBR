# App settings
DEBUG=false

# CORS origins (comma-separated)
CORS_ORIGINS=["http://localhost:5173","chrome-extension://*"]

# Neon PostgreSQL / run-log storage
# Program request run tracking uses this connection and creates
# program_request_runs automatically when QBR requests are submitted.
DATABASE_URL=

# Alternate (advanced): SQL-over-HTTP endpoint that accepts POST with JSON:
#   { "query": "SELECT ...", "params": [...] }
# and returns { "fields": [...], "rows": [...] } or equivalent.
# If using a PostgREST-style URL, create program_request_runs once with:
#   backend/sql/program_request_runs.sql
NEON_API_URL=

# Legacy compatibility only: n8n is not part of the active extension -> runner -> PPTX flow.
QBR_AGENT_WEBHOOK_URL=
