# App settings
DEBUG=false

# CORS origins (comma-separated)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Neon PostgreSQL (for Onboarding Tracker)
# Recommended: use a direct Postgres connection string (no Neon Auth needed).
# Format example:
#   postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=

# Alternate (advanced): SQL-over-HTTP endpoint that accepts POST with JSON:
#   { "query": "SELECT ...", "params": [...] }
# and returns { "fields": [...], "rows": [...] } or equivalent.
# Get this from Neon Console: Project > Connection details > Data API / HTTP.
NEON_API_URL=

# QBR n8n webhook
QBR_AGENT_WEBHOOK_URL=https://coe-n8n.coe-untrust-eu-de.prod.tddrift.net/webhook/qbr-v4-presenton-1e2f9f4d
