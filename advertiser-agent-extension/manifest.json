{
  "manifest_version": 3,
  "name": "Advertiser Agent",
  "version": "0.1.0",
  "description": "Developer UI for submitting Advertiser Agent workflow requests.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Advertiser Agent"
  }
}
